{
  "name": "chrome-extension-tarou",
  "type": "module",
  "version": "0.0.1",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "vite --port 1234 --open",
    "ba": "run-s clear build:alp build:prepare build:js",
    "bp": "run-s clear build:prod build:prepare build:js",
    "build:alp": "vite build --mode development",
    "build:prod": "vite build --mode production",
    "build:prepare": "tsx scripts/prepare.ts",
    "build:js": "vite build --config vite.config.content.mts && vite build --config vite.config.inject.mts",
    "zip": "tsx scripts/zip.ts",
    "log": "tsx scripts/log.ts",
    "clear": "rimraf --glob dist",
    "up": "taze major -I",
    "lint": "eslint --cache ."
  },
  "devDependencies": {
    "@antfu/eslint-config": "^7.7.3",
    "@iconify/json": "^2.2.456",
    "@iconify/vue": "^5.0.0",
    "@types/ali-oss": "^6.23.3",
    "@types/archiver": "^7.0.0",
    "@types/chrome": "^0.1.38",
    "@types/jquery": "^3.5.34",
    "@types/lodash-es": "^4.17.12",
    "@types/md5": "^2.3.6",
    "@types/node": "^22",
    "@unocss/eslint-config": "^66.6.7",
    "@unocss/reset": "^66.6.7",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vueuse/components": "^14.2.1",
    "@vueuse/core": "^14.2.1",
    "@vueuse/shared": "^14.2.1",
    "@zumer/snapdom": "^2.7.0",
    "ali-oss": "^6.23.0",
    "archiver": "^7.0.1",
    "cheerio": "^1.2.0",
    "clipboardy": "^5.3.1",
    "copy-text-to-clipboard": "^3.2.2",
    "dayjs": "^1.11.20",
    "echarts": "5.6.0",
    "element-plus": "^2.13.6",
    "eslint": "^10.1.0",
    "eslint-plugin-format": "^2.0.1",
    "fast-glob": "^3.3.3",
    "lodash-es": "^4.17.23",
    "md5": "^2.3.0",
    "npm-run-all": "^4.1.5",
    "rimraf": "^6.1.3",
    "tsx": "^4.21.0",
    "typescript": "5.7.3",
    "unocss": "^66.6.7",
    "unplugin-auto-import": "^21.0.0",
    "unplugin-vue-components": "^32.0.0",
    "uuid": "^13.0.0",
    "vite": "^8.0.3",
    "vue": "^3.5.31",
    "vue-draggable-next": "^2.3.0",
    "webext-bridge": "^6.0.1"
  }
}
